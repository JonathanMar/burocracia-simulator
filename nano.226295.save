```gitignore id="yo8t4n"
# ── NODE ─────────────────────────────────────────────
node_modules/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build
dist/
build/

# Vite
.vite/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── PYTHON / VENV ───────────────────────────────────
env/
venv/
.venv/

__pycache__/
*.pyc
*.pyo
*.pyd

# ── OS ──────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── EDITORS ─────────────────────────────────────────
.vscode/
.idea/

# ── TEMP ────────────────────────────────────────────
*.tmp
*.temp
*.swp

# ── TESTS / COVERAGE ───────────────────────────────
coverage/

# ── CACHE ──────────────────────────────────────────
.cache/
.eslintcache
```
